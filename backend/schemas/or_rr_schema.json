{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OR / RR Extraction Schema",
  "description": "Schema for extracting odds ratio or risk ratio data from epidemiological studies.",
  "type": "object",
  "required": ["metadata", "methods", "analysis"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "study_id": { "type": ["string", "null"], "description": "Study identifier (e.g., DOI)" },
        "title": { "type": "string", "description": "Full study title — MANDATORY" },
        "authors": { "type": ["string", "null"], "description": "First author or all authors" },
        "year": { "type": ["integer", "null"], "description": "Publication year" },
        "journal": { "type": ["string", "null"], "description": "Journal name" },
        "country": { "type": ["string", "null"], "description": "Country where study was conducted" },
        "continent": { "type": ["string", "null"], "description": "Continent (optional, inferred from country)" }
      }
    },
    "methods": {
      "type": "object",
      "properties": {
        "study_design": { "type": ["string", "null"], "description": "Study design (e.g., Case-control, Cohort, RCT)" },
        "population": { "type": ["string", "null"], "description": "Study population description" },
        "sample_size": { "type": ["integer", "null"], "description": "Total sample size" },
        "exposure_definition": { "type": ["string", "null"], "description": "How exposure was defined" },
        "outcome_definition": { "type": ["string", "null"], "description": "How outcome was defined" }
      }
    },
    "analysis": {
      "type": "object",
      "required": ["exposure", "outcome", "effect_measure"],
      "properties": {
        "exposure": { "type": "string", "description": "Exposure variable — empty string if not relevant" },
        "outcome": { "type": "string", "description": "Outcome variable — empty string if not relevant" },
        "effect_measure": { "type": "string", "enum": ["OR", "RR"], "description": "Must be 'OR' or 'RR'" },
        "effect_value": { "type": ["number", "null"], "description": "Point estimate of OR or RR" },
        "ci_lower": { "type": ["number", "null"], "description": "95% CI lower bound" },
        "ci_upper": { "type": ["number", "null"], "description": "95% CI upper bound" },
        "p_value": { "type": ["number", "null"], "description": "Statistical p-value" },
        "two_by_two_table": {
          "type": "object",
          "description": "Optional 2×2 contingency table. Enables recomputation of OR/RR.",
          "properties": {
            "a": { "type": ["integer", "null"], "minimum": 0, "description": "Exposed with outcome" },
            "b": { "type": ["integer", "null"], "minimum": 0, "description": "Exposed without outcome" },
            "c": { "type": ["integer", "null"], "minimum": 0, "description": "Control with outcome" },
            "d": { "type": ["integer", "null"], "minimum": 0, "description": "Control without outcome" }
          }
        },
        "group_statistics": {
          "type": "object",
          "description": "Group-level statistics for exposed and control groups",
          "properties": {
            "exposed": {
              "type": "object",
              "properties": {
                "n": { "type": ["integer", "null"], "minimum": 0, "description": "Sample size in exposed group" },
                "mean": { "type": ["number", "null"], "description": "Mean in exposed group" },
                "sd": { "type": ["number", "null"], "minimum": 0, "description": "SD in exposed group" }
              }
            },
            "control": {
              "type": "object",
              "properties": {
                "n": { "type": ["integer", "null"], "minimum": 0, "description": "Sample size in control group" },
                "mean": { "type": ["number", "null"], "description": "Mean in control group" },
                "sd": { "type": ["number", "null"], "minimum": 0, "description": "SD in control group" }
              }
            }
          }
        },
        "adjustment_variables": { "type": "array", "items": { "type": "string" }, "description": "Variables adjusted for" }
      }
    }
  }
}
